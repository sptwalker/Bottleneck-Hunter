# LLM Provider: openai / anthropic / google / deepseek / qwen / glm / ollama / openrouter / siliconflow / agnes / kimi
LLM_PROVIDER=openai

# API Keys (fill in what you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
AGNES_API_KEY=
MOONSHOT_API_KEY=

# Model selection
DEEP_THINK_LLM=gpt-5.5
QUICK_THINK_LLM=gpt-5.4

# Cross-validation models (comma-separated, used for multi-model validation)
VALIDATION_MODELS=gpt-5.5,claude-opus-4-7,deepseek-v4-pro

# Output language: zh / en
OUTPUT_LANGUAGE=zh
