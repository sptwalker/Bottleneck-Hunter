# LLM Provider: openai / anthropic / google / deepseek / qwen / glm / minimax / openrouter / siliconflow / agnes / kimi
LLM_PROVIDER=openai

# API Keys (fill in what you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
AGNES_API_KEY=
MOONSHOT_API_KEY=

# Model selection
DEEP_THINK_LLM=gpt-5.5
QUICK_THINK_LLM=gpt-5.4

# Cross-validation models (comma-separated, used for multi-model validation)
VALIDATION_MODELS=gpt-5.5,claude-opus-4-7,deepseek-v4-pro

# Output language: zh / en
OUTPUT_LANGUAGE=zh

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# JWT secret (auto-generated if not set, persisted to data/.jwt_secret)
# BH_JWT_SECRET=

# ── 邮箱验证 SMTP（注册/改邮箱发送验证码用）──
# 未配置 SMTP_HOST 时，验证码会打印到服务器日志（开发兜底），注册仍可走通。
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_account@example.com
# SMTP_PASSWORD=your_password_or_app_token
# SMTP_FROM=BottleneckHunter <no-reply@example.com>
# SMTP_USE_TLS=true

